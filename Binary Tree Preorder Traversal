class Solution {
public:
    vector<int> preorderTraversal(TreeNode* root) {
        vector<int> res;
        if (!root) return res;

        stack<TreeNode*> s;
        s.push(root);

        while (!s.empty()) {
            TreeNode* curr = s.top();
            s.pop();
            res.push_back(curr->val);

            // Push right child first so left is processed next (LIFO)
            if (curr->right) s.push(curr->right);
            if (curr->left) s.push(curr->left);
        }
        return res;
    }
};
