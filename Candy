#include <vector>
#include <numeric>
#include <algorithm>

class Solution {
public:
    int candy(std::vector<int>& ratings) {
        int n = ratings.size();
        if (n <= 1) return n;

        std::vector<int> candies(n, 1);

        // 1. Forward pass: Compare with left neighbor
        for (int i = 1; i < n; i++) {
            if (ratings[i] > ratings[i - 1]) {
                candies[i] = candies[i - 1] + 1;
            }
        }

        // 2. Backward pass: Compare with right neighbor
        for (int i = n - 2; i >= 0; i--) {
            if (ratings[i] > ratings[i + 1]) {
                // Must be greater than right neighbor AND keep the left-neighbor rule
                candies[i] = std::max(candies[i], candies[i + 1] + 1);
            }
        }

        // Return the sum of all candies
        return std::accumulate(candies.begin(), candies.end(), 0);
    }
};
