#include <vector>
#include <unordered_map>

class Solution {
    std::unordered_map<int, int> inMap;
    int preIdx = 0;

public:
    TreeNode* buildTree(std::vector<int>& preorder, std::vector<int>& inorder) {
        // Pre-map inorder indices for O(1) lookups
        for (int i = 0; i < inorder.size(); i++) {
            inMap[inorder[i]] = i;
        }
        return solve(preorder, 0, inorder.size() - 1);
    }

private:
    TreeNode* solve(std::vector<int>& preorder, int inStart, int inEnd) {
        // Base case: no elements in this subtree
        if (inStart > inEnd) return nullptr;

        // 1. Pick the current root from preorder traversal
        int rootVal = preorder[preIdx++];
        TreeNode* root = new TreeNode(rootVal);

        // 2. Find the root's index in the inorder array
        int mid = inMap[rootVal];

        // 3. Recursively build left and right subtrees
        // Important: Build left before right to follow preorder logic
        root->left = solve(preorder, inStart, mid - 1);
        root->right = solve(preorder, mid + 1, inEnd);

        return root;
    }
};
