class Solution {
public:
    Node* copyRandomList(Node* head) {
        if (!head) return nullptr;

        // 1. Create copy nodes and weave them into the original list
        // Original: A -> B -> C
        // Weaved:   A -> A' -> B -> B' -> C -> C'
        Node* curr = head;
        while (curr) {
            Node* copy = new Node(curr->val);
            copy->next = curr->next;
            curr->next = copy;
            curr = copy->next;
        }

        // 2. Set random pointers for the copied nodes
        curr = head;
        while (curr) {
            if (curr->random) {
                curr->next->random = curr->random->next;
            }
            curr = curr->next->next;
        }

        // 3. Separate the two lists (Restore original and extract copy)
        Node* dummy = new Node(0);
        Node* copyCurr = dummy;
        curr = head;
        while (curr) {
            copyCurr->next = curr->next;
            curr->next = curr->next->next;
            
            copyCurr = copyCurr->next;
            curr = curr->next;
        }

        return dummy->next;
    }
};
