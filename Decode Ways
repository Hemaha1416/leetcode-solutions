#include <string>
#include <vector>
using namespace std;

class Solution {
public:
    int numDecodings(string s) {
        int n = s.length();
        if (n == 0 || s[0] == '0') return 0;

        // dp[i] stores the number of ways to decode the prefix of length i
        vector<int> dp(n + 1, 0);
        dp[0] = 1; // Base case: empty string has 1 way
        dp[1] = 1; // Base case: first char is not '0', so 1 way

        for (int i = 2; i <= n; i++) {
            // Check if single digit (s[i-1]) is valid (1-9)
            if (s[i-1] != '0') {
                dp[i] += dp[i-1];
            }

            // Check if two digits (s[i-2] and s[i-1]) form a valid letter (10-26)
            int twoDigit = stoi(s.substr(i-2, 2));
            if (twoDigit >= 10 && twoDigit <= 26) {
                dp[i] += dp[i-2];
            }
        }

        return dp[n];
    }
};
