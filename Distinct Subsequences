#include <vector>
#include <string>

class Solution {
public:
    int numDistinct(string s, string t) {
        int m = s.length(), n = t.length();
        // Use unsigned long to prevent overflow during intermediate steps 
        // even though result fits in 32-bit int.
        std::vector<unsigned long long> dp(n + 1, 0);

        // Base case: An empty t is a subsequence of any s (exactly 1 way)
        dp[0] = 1;

        for (int i = 1; i <= m; i++) {
            // Iterate backwards to use the results from the "previous row"
            for (int j = n; j >= 1; j--) {
                if (s[i - 1] == t[j - 1]) {
                    dp[j] += dp[j - 1];
                }
            }
        }

        return (int)dp[n];
    }
};
