#include <vector>
#include <numeric>

class Solution {
public:
    int canCompleteCircuit(std::vector<int>& gas, std::vector<int>& cost) {
        int totalSum = 0;
        int currentGas = 0;
        int startNode = 0;

        for (int i = 0; i < gas.size(); i++) {
            int diff = gas[i] - cost[i];
            totalSum += diff;
            currentGas += diff;

            // If we run out of gas, this startNode is invalid
            if (currentGas < 0) {
                // Try starting from the next station
                startNode = i + 1;
                currentGas = 0;
            }
        }

        // If total gas is less than total cost, no solution exists
        return (totalSum >= 0) ? startNode : -1;
    }
};
