#include <vector>
#include <unordered_map>
#include <numeric>
#include <algorithm>
#include <cmath>

using namespace std;

class Solution {
private:
    // Custom hash function for std::pair to use in unordered_map
    struct pair_hash {
        template <class T1, class T2>
        size_t operator() (const pair<T1, T2>& p) const {
            auto h1 = hash<T1>{}(p.first);
            auto h2 = hash<T2>{}(p.second);
            // Combine hashes safely
            return h1 ^ (h2 + 0x9e3779b9 + (h1 << 6) + (h1 >> 2));
        }
    };

public:
    int maxPoints(vector<vector<int>>& points) {
        int n = points.size();
        if (n <= 2) return n;

        int max_points = 1;

        for (int i = 0; i < n; ++i) {
            // Key: reduced fraction {dx, dy}, Value: count
            unordered_map<pair<int, int>, int, pair_hash> slopes;
            int local_max = 0;

            for (int j = i + 1; j < n; ++j) {
                int dx = points[j][0] - points[i][0];
                int dy = points[j][1] - points[i][1];

                // Reduce the fraction using Greatest Common Divisor
                int gcd = std::gcd(dx, dy);
                dx /= gcd;
                dy /= gcd;

                // Standardise sign for consistent map matching
                if (dx < 0) {
                    dx = -dx;
                    dy = -dy;
                } else if (dx == 0) {
                    dy = abs(dy); // Vertical line
                }

                slopes[{dx, dy}]++;
                local_max = max(local_max, slopes[{dx, dy}]);
            }
            
            // +1 includes the reference point points[i]
            max_points = max(max_points, local_max + 1);
        }

        return max_points;
    }
};
