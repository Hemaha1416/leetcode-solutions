class Solution {
public:
    int maxDepth(TreeNode* root) {
        // Base case: if the node is null, the depth is 0
        if (root == nullptr) {
            return 0;
        }
        
        // Recursive step: 1 (current node) + the max depth of subtrees
        return std::max(maxDepth(root->left), maxDepth(root->right)) + 1;
    }
};
