#include <vector>

class Solution {
private:
    void dfs(std::vector<std::vector<char>>& grid, int r, int c, int m, int n) {
        // Base case: check boundary conditions and if the cell is water
        if (r < 0 || r >= m || c < 0 || c >= n || grid[r][c] == '0') {
            return;
        }

        // Mark the current cell as visited by changing '1' to '0'
        grid[r][c] = '0';

        // Recursively visit all 4 orthogonal neighbors
        dfs(grid, r + 1, c, m, n); // Down
        dfs(grid, r - 1, c, m, n); // Up
        dfs(grid, r, c + 1, m, n); // Right
        dfs(grid, r, c - 1, m, n); // Left
    }

public:
    int numIslands(std::vector<std::vector<char>>& grid) {
        if (grid.empty() || grid[0].empty()) {
            return 0;
        }

        int m = grid.size();
        int n = grid[0].size();
        int island_count = 0;

        // Scan every cell in the 2D grid
        for (int r = 0; r < m; ++r) {
            for (int c = 0; c < n; ++c) {
                // If a piece of land is found, it's a new island
                if (grid[r][c] == '1') {
                    ++island_count;
                    // Sink the entire island using DFS
                    dfs(grid, r, c, m, n);
                }
            }
        }

        return island_count;
    }
};
