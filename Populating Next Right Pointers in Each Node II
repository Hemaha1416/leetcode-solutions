class Solution {
public:
    Node* connect(Node* root) {
        Node* curr = root; // The node we are currently at in the parent level
        
        while (curr) {
            Node dummy(0); // Temporary head for the next level
            Node* tail = &dummy; // Pointer to build the next level
            
            // Traverse the current level and link its children
            while (curr) {
                if (curr->left) {
                    tail->next = curr->left;
                    tail = tail->next;
                }
                if (curr->right) {
                    tail->next = curr->right;
                    tail = tail->next;
                }
                curr = curr->next; // Move to the next node in the parent level
            }
            
            // Move down to the start of the next level
            curr = dummy.next;
        }
        
        return root;
    }
};
