#include <vector>
#include <algorithm>

class Solution {
public:
    void sortColors(std::vector<int>& nums) {
        int low = 0;
        int mid = 0;
        int high = nums.size() - 1;

        while (mid <= high) {
            if (nums[mid] == 0) {
                // If it's red, swap to the front and move both pointers
                std::swap(nums[low++], nums[mid++]);
            } else if (nums[mid] == 1) {
                // If it's white, it's already in the right area, just move mid
                mid++;
            } else {
                // If it's blue, swap to the back. 
                // Don't move mid yet, as we need to inspect the swapped element!
                std::swap(nums[mid], nums[high--]);
            }
        }
    }
};
