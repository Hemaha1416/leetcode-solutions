#include <vector>
#include <algorithm>

class Solution {
public:
    std::vector<std::vector<int>> subsetsWithDup(std::vector<int>& nums) {
        std::vector<std::vector<int>> result;
        std::vector<int> current;
        
        // 1. Sort the array so that duplicates are adjacent
        std::sort(nums.begin(), nums.end());
        
        backtrack(0, nums, current, result);
        return result;
    }

private:
    void backtrack(int start, std::vector<int>& nums, std::vector<int>& current, std::vector<std::vector<int>>& result) {
        // Add the current subset to the result list
        result.push_back(current);

        for (int i = start; i < nums.size(); i++) {
            // 2. Skip duplicates: if the current element is the same as the previous one
            // and it's not the first element in this recursion level.
            if (i > start && nums[i] == nums[i - 1]) continue;

            current.push_back(nums[i]);        // Choose
            backtrack(i + 1, nums, current, result); // Explore
            current.pop_back();                // Un-choose (backtrack)
        }
    }
};
