#include <vector>

class Solution {
public:
    void solve(std::vector<std::vector<char>>& board) {
        if (board.empty()) return;
        int rows = board.size();
        int cols = board[0].size();

        // 1. Boundary DFS: Find 'O's connected to the edges
        for (int i = 0; i < rows; i++) {
            dfs(board, i, 0);            // Left edge
            dfs(board, i, cols - 1);    // Right edge
        }
        for (int j = 0; j < cols; j++) {
            dfs(board, 0, j);            // Top edge
            dfs(board, rows - 1, j);    // Bottom edge
        }

        // 2. Final pass
        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                if (board[i][j] == 'O') board[i][j] = 'X'; // Surrounded
                else if (board[i][j] == '#') board[i][j] = 'O'; // Restored
            }
        }
    }

private:
    void dfs(std::vector<std::vector<char>>& board, int r, int c) {
        if (r < 0 || r >= board.size() || c < 0 || c >= board[0].size() || board[r][c] != 'O') {
            return;
        }
        
        board[r][c] = '#'; // Mark as a "survivor"
        
        dfs(board, r + 1, c);
        dfs(board, r - 1, c);
        dfs(board, r, c + 1);
        dfs(board, r, c - 1);
    }
};
