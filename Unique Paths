#include <vector>
using namespace std;

class Solution {
public:
    int uniquePaths(int m, int n) {
        // Space Optimized DP: O(n) space complexity
        // Initialize with 1s: only 1 way to reach any cell in the first row
        vector<int> dp(n, 1);

        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {
                // Current cell paths = Paths from Top (dp[j]) + Paths from Left (dp[j-1])
                dp[j] += dp[j - 1];
            }
        }
        
        return dp[n - 1];
    }
};
