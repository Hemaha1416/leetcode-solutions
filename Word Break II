#include <vector>
#include <string>
#include <unordered_set>
#include <unordered_map>

using namespace std;

class Solution {
    unordered_map<string, vector<string>> memo;

public:
    vector<string> wordBreak(string s, vector<string>& wordDict) {
        // If we already solved this substring, return the cached result
        if (memo.count(s)) return memo[s];
        if (s.empty()) return {""};

        unordered_set<string> wordSet(wordDict.begin(), wordDict.end());
        vector<string> result;

        for (int i = 1; i <= s.length(); i++) {
            string word = s.substr(0, i);
            
            // If the prefix is a valid word
            if (wordSet.count(word)) {
                // Get all possible completions for the remaining suffix
                vector<string> rest = wordBreak(s.substr(i), wordDict);
                
                for (string str : rest) {
                    result.push_back(word + (str.empty() ? "" : " ") + str);
                }
            }
        }

        return memo[s] = result;
    }
};
