#include <vector>
#include <algorithm>

class Solution {
public:
    int calculateMinimumHP(std::vector<std::vector<int>>& dungeon) {
        int m = dungeon.size();
        int n = dungeon[0].size();
        
        // dp[i][j] represents the minimum health needed before entering room (i, j)
        std::vector<std::vector<int>> dp(m, std::vector<int>(n, 0));
        
        // 1. Base Case: Calculate health needed for the princess's room (bottom-right)
        dp[m - 1][n - 1] = std::max(1, 1 - dungeon[m - 1][n - 1]);
        
        // 2. Fill the last column (can only move downward)
        for (int i = m - 2; i >= 0; --i) {
            dp[i][n - 1] = std::max(1, dp[i + 1][n - 1] - dungeon[i][n - 1]);
        }
        
        // 3. Fill the last row (can only move rightward)
        for (int j = n - 2; j >= 0; --j) {
            dp[m - 1][j] = std::max(1, dp[m - 1][j + 1] - dungeon[m - 1][j]);
        }
        
        // 4. Fill the rest of the DP table from bottom to top, right to left
        for (int i = m - 2; i >= 0; --i) {
            for (int j = n - 2; j >= 0; --j) {
                // Knight chooses the path requiring less health
                int min_health_next = std::min(dp[i + 1][j], dp[i][j + 1]);
                dp[i][j] = std::max(1, min_health_next - dungeon[i][j]);
            }
        }
        
        // The answer is the minimum health required at the starting room (0, 0)
        return dp[0][0];
    }
};
