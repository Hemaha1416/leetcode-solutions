#include <string>

using namespace std;

class Solution {
public:
    int titleToNumber(string columnTitle) {
        int result = 0;
        
        for (char ch : columnTitle) {
            // Shift the current result to the left by one base-26 place
            // and add the value of the current character (A=1, B=2, ...)
            result = result * 26 + (ch - 'A' + 1);
        }
        
        return result;
    }
};
