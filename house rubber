#include <vector>
#include <algorithm>

class Solution {
public:
    int rob(std::vector<int>& nums) {
        int rob1 = 0; // Max profit up to house i-1
        int rob2 = 0; // Max profit up to house i-2
        
        for (int n : nums) {
            int temp = std::max(n + rob2, rob1);
            rob2 = rob1;
            rob1 = temp;
        }
        
        return rob1;
    }
};
