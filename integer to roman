#include <string>
#include <vector>

class Solution {
public:
    std::string intToRoman(int num) {
        // Define mapping of values and their corresponding Roman symbols
        // We include the subtractive forms (900, 400, 90, 40, 9, 4) as unique symbols
        std::vector<std::pair<int, std::string>> romanMap = {
            {1000, "M"}, {900, "CM"}, {500, "D"}, {400, "CD"},
            {100, "C"}, {90, "XC"}, {50, "L"}, {40, "XL"},
            {10, "X"}, {9, "IX"}, {5, "V"}, {4, "IV"}, {1, "I"}
        };

        std::string result = "";

        for (auto const& [value, symbol] : romanMap) {
            // While the current value can be subtracted from num
            while (num >= value) {
                result += symbol; // Append the symbol
                num -= value;    // Subtract the value
            }
        }

        return result;
    }
};
