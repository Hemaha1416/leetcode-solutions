#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

class Solution {
public:
    std::string largestNumber(std::vector<int>& nums) {
        // Step 1: Convert integers to strings
        std::vector<std::string> num_strs;
        for (int num : nums) {
            num_strs.push_back(std::to_string(num));
        }
        
        // Step 2: Sort strings using custom comparison logic
        std::sort(num_strs.begin(), num_strs.end(), [](const std::string& a, const std::string& b) {
            return a + b > b + a;
        });
        
        // Step 3: Handle the edge case where the largest number is "0"
        if (num_strs[0] == "0") {
            return "0";
        }
        
        // Step 4: Join all strings together
        std::string result = "";
        for (const std::string& str : num_strs) {
            result += str;
        }
        
        return result;
    }
};
