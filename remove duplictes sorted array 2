#include <vector>

class Solution {
public:
    std::vector<int> grayCode(int n) {
        std::vector<int> result;
        int size = 1 << n; // Total 2^n elements
        result.reserve(size);

        for (int i = 0; i < size; i++) {
            // Standard Binary to Gray conversion: i ^ (i >> 1)
            result.push_back(i ^ (i >> 1));
        }

        return result;
    }
};
