#include <vector>
#include <unordered_map>

using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        // Map to store: key = value of number, value = its index
        unordered_map<int, int> numMap;
        
        for (int i = 0; i < nums.size(); i++) {
            int complement = target - nums[i];
            
            // Check if the complement exists in the map
            if (numMap.find(complement) != numMap.end()) {
                // If found, return the index of complement and current index
                return {numMap[complement], i};
            }
            
            // Otherwise, store current number and its index for future reference
            numMap[nums[i]] = i;
        }
        
        // Since the problem guarantees exactly one solution,
        // this part should theoretically never be reached.
        return {};
    }
};
